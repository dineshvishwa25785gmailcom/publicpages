# CodeXClear — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Base URL for the .NET Core API (no trailing slash)
VITE_API_BASE_URL=https://codexclear.com

# External app URLs
VITE_INVOICE_APP_URL=https://rnstoreapp.vercel.app/login?app=invoice
VITE_MUSIC_APP_URL=https://rnstoreapp.vercel.app/login?app=music
VITE_LOGIN_URL=https://rnstoreapp.vercel.app/login
VITE_REGISTER_URL=https://rnstoreapp.vercel.app/register
